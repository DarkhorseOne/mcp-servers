{
  "name": "@darkhorseone/mcp-server-uk-parliament-committees",
  "version": "1.0.1",
  "description": "MCP server for UK Parliament Committees API",
  "license": "MIT",
  "author": "DarkhorseOne Limited",
  "homepage": "https://github.com/DarkhorseOne/mcp-servers",
  "mcpName": "io.github.nick-ma/uk-parliament-committees",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DarkhorseOne/mcp-servers.git"
  },
  "type": "module",
  "bin": {
    "mcp-server-uk-parliament-committees": "dist/index.js",
    "mcp-server-uk-parliament-committees-http": "dist/http.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/http.ts --format esm --dts --clean && node ./scripts/add-shebang.mjs",
    "check:tarball:shebang": "node ./scripts/verify-tarball-shebang.mjs",
    "prepack": "pnpm run build && pnpm run check:tarball:shebang",
    "prepublishOnly": "pnpm run check:tarball:shebang",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "start:http": "node dist/http.js",
    "inspect:local": "pnpm run build && npx -y @modelcontextprotocol/inspector node ./dist/index.js",
    "inspect:npm": "npx -y @modelcontextprotocol/inspector npx -y -p @darkhorseone/mcp-server-uk-parliament-committees mcp-server-uk-parliament-committees"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
