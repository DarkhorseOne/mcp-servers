{
  "name": "mcp-servers",
  "version": "1.0.0",
  "description": "A mcp servers repo built by DarkhorseOne Limited",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "install:all": "pnpm install",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "pnpm -r exec rimraf dist",
    "dev:gov-uk": "pnpm --filter @darkhorseone/mcp-server-gov-uk dev",
    "dev:companies-house": "pnpm --filter @darkhorseone/mcp-server-companies-house dev",
    "dev:uk-parliament-interests": "pnpm --filter @darkhorseone/mcp-server-uk-parliament-interests dev",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "publish:packages": "pnpm publish -r --access public",
    "create:server": "node ./scripts/create-server.mjs",
    "inspect:ukpm:local": "npx @modelcontextprotocol/inspector node ./servers/uk-parliament-members/dist/index.js",
    "inspect:ukpm:npm": "npx @modelcontextprotocol/inspector npx -y @darkhorseone/mcp-server-uk-parliament-members"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
